// commands.jsonc — score_account_via_latitude @ 1.0.0
//
// Net-new agency function (no Clay table source). Prompt + jsonSchema live
// at enrichment-functions/score_account_via_latitude/latitude-prompt-spec.md
// and are pushed to Latitude as `account_scoring/score_tier` (or per-recipe override).
//
// Pipeline shape (mirrors classify_via_latitude):
//   1. build_request    — JS: compose Latitude POST body, resolve defaults.
//   2. latitude_call    — HTTP: POST to Latitude documents/run.
//   3. compose_output   — JS: extract tier + reasoning, default-to-mid-tier on failure.
//
// Input shape (when called as a sub-workflow):
//   row.input.account_signals          required (JSON string)
//   row.input.tier_rules_json          required (JSON string)
//   row.input.latitude_prompt_path     optional (default account_scoring/score_tier)
//   row.input.latitude_project_id      optional (defaults to LATITUDE_PROJECT_ID env var)
//   row.input.latitude_version         optional (default "live")
//   row.input.latitude_api_key         required
//   row.input.timeout_ms               optional (default 60000)

{
  "commands": [
    {
      "alias": "build_request",
      "description": "Compose Latitude POST body. Bakes your tier_rules_json + the row's account_signals into the parameters object the prompt template expects.",
      "operation": "run_javascript",
      "tool": "run_javascript",
      "payload": {
        "code": "const i = row.input || {}; const projectId = i.latitude_project_id || (typeof env !== 'undefined' && env.LATITUDE_PROJECT_ID) || null; if (!projectId) throw new Error('latitude_project_id missing — pass input.latitude_project_id or set LATITUDE_PROJECT_ID env var'); const version = i.latitude_version || 'live'; const promptPath = i.latitude_prompt_path || 'account_scoring/score_tier'; const url = 'https://gateway.latitude.so/api/v3/projects/' + projectId + '/versions/' + encodeURIComponent(version) + '/documents/run'; if (!i.account_signals) throw new Error('account_signals missing'); if (!i.tier_rules_json) throw new Error('tier_rules_json missing'); return { url: url, body: { parameters: { account_signals: i.account_signals, tier_rules_json: i.tier_rules_json }, path: promptPath, stream: false }, timeout_ms: i.timeout_ms || 60000 };"
      }
    },

    {
      "alias": "latitude_call",
      "description": "POST to Latitude documents/run. Auth header is the caller-supplied API key (same security model as classify_via_latitude — baked into the compiled playbook).",
      "operation": "generic_http_request",
      "tool": "generic_http_request",
      "run_if_js": "Boolean(row.build_request && row.build_request.result && row.build_request.result.data && row.build_request.result.data.url)",
      "payload": {
        "method": "POST",
        "url": "{{build_request.result.data.url}}",
        "headers": {
          "Authorization": "Bearer {{row.input.latitude_api_key}}",
          "Content-Type": "application/json"
        },
        "body_json": "{{build_request.result.data.body}}",
        "timeout_ms": "{{build_request.result.data.timeout_ms}}"
      },
      "extract_js": "(output_data) => { const r = (output_data && output_data.result) || output_data || {}; const body = r.body || r.data || r; const resp = body && body.response; if (!resp) return { ok: false, error: 'no response field', raw: body }; let obj = resp.object; if (!obj && resp.text) { if (typeof resp.text === 'object') { obj = resp.text; } else if (typeof resp.text === 'string' && resp.text.trim()) { try { obj = JSON.parse(resp.text.replace(/^```json\\n?/, '').replace(/\\n?```$/, '')); } catch (e) { return { ok: false, error: 'json parse failed', raw: resp.text }; } } } if (!obj) return { ok: false, error: 'no object in response', raw: resp }; return { ok: true, parsed: obj, conversation_uuid: (body.uuid || body.conversationUuid || null), raw: body }; }"
    },

    {
      "alias": "compose_output",
      "description": "Extract tier + reasoning. Default-to-mid-tier on Latitude failure or unparseable response (typically Tier N-1 in N-tier; 'OK / lower-priority' bucket per the bias rule). NEVER defaults to Tier 1 (false-positive risk) or top-tier (false-disqualify risk).",
      "operation": "run_javascript",
      "tool": "run_javascript",
      "payload": {
        "code": "const lc = row.latitude_call && row.latitude_call.result; const ext = lc && lc.data; const ok = ext && ext.ok === true; const obj = ok ? ext.parsed : null; const i = row.input || {}; let tierRules = null; try { tierRules = i.tier_rules_json ? JSON.parse(i.tier_rules_json) : null; } catch (e) { tierRules = null; } const tierCount = (tierRules && tierRules.tier_count) || 4; const fallbackTier = Math.max(1, tierCount - 1); const verifSignals = { latitude: { ran: !!lc, ok: !!ok, error: ok ? null : ((ext && ext.error) || 'latitude_call did not run'), raw_response_excerpt: ok ? (ext.raw && JSON.stringify(ext.raw).slice(0, 500)) : null }, scoring_model: tierRules ? { schema_version: tierRules.schema_version, tier_count: tierRules.tier_count, object_type: tierRules.object_type } : null }; if (!ok || !obj) { return { tier: null, tier_label: null, tier_reasoning: ok ? null : ('Latitude call failed: ' + ((ext && ext.error) || 'unknown')), sub_scores: null, confidence: null, latitude_conversation_uuid: ext ? (ext.conversation_uuid || null) : null, verification_signals: verifSignals }; } let tierVal = (typeof obj.tier === 'number' && obj.tier >= 1) ? obj.tier : fallbackTier; let tierLabel = obj.tier_label || null; if (!tierLabel && tierRules && Array.isArray(tierRules.tiers)) { const match = tierRules.tiers.find(function(t){ return t.tier === tierVal; }); if (match) tierLabel = match.label; } return { tier: tierVal, tier_label: tierLabel, tier_reasoning: obj.reasoning || null, sub_scores: obj.sub_scores || null, confidence: typeof obj.confidence === 'number' ? obj.confidence : null, latitude_conversation_uuid: ext.conversation_uuid || null, verification_signals: verifSignals };"
      }
    }
  ]
}
