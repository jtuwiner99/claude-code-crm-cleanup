# Required keys. Both are needed for the default /crm-cleanup flow.
# (For HubSpot users — `python tools/install_hubspot.py` is the easiest way to
# get real CRM data into tmp/hubspot-properties.csv with no extra keys to set.
# See README → "Use your real CRM data".)

# Required for the default (v1, Anthropic-direct) recipes
ANTHROPIC_API_KEY=<your-anthropic-key>

# Required for actually running the Deepline pipeline
# Get one at https://deepline.ai (free tier covers a small demo run)
DEEPLINE_API_KEY=<your-deepline-key>

# STRONGLY RECOMMENDED for /crm-cleanup — enables a live direct LinkedIn scrape
# via the Harvest API, so `numberofemployees` returns the EXACT integer instead
# of the band lower-bound the AI agent can read from public search snippets
# (e.g. with Harvest: "1,113"; without: "1,001" floored from the "1,001-5,000"
# band). The playbook works fine without it — degrades gracefully — but the
# accuracy delta is meaningful, especially for Phase 4 golden-dataset iteration.
# Get one at https://harvest-api.com/admin/api-keys
HARVEST_API_KEY=<your-harvest-key>

# OPTIONAL: only needed for `pro-*` recipes that use Latitude for prompt iteration
# Get one at https://latitude.so
# LATITUDE_API_KEY=
# LATITUDE_PROJECT_ID=

# OPTIONAL: only needed for `tools/install_hubspot.py` (pulls real properties from your HubSpot)
# Defaults work — Sculpted's hosted OAuth app handles the rest.
# SCULPTED_HUBSPOT_INSTALL_BASE=https://aofpyrbquqxovunsxosb.supabase.co/functions/v1
