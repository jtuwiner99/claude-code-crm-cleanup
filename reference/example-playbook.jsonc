{
  "version": 1,
  "commands": [
    {
      "alias": "domain_clean",
      "tool": "run_javascript",
      "operation": "run_javascript",
      "payload": {
        "code": "const raw = row['Company Domain Name'] || row.domain || ''; return String(raw).toLowerCase().replace(/^https?:\\/\\//,'').replace(/^www\\./,'').split('/')[0].trim() || null;"
      }
    },
    {
      "with_waterfall": "company_core",
      "commands": [
        {
          "alias": "company_core_apollo",
          "tool": "apollo_enrich_company",
          "operation": "apollo_enrich_company",
          "payload": {
            "domain": "{{domain_clean}}"
          },
          "extract_js": "(output_data) => { const o = output_data && output_data.result && output_data.result.organization; if (!o || !o.name) return null; return { name: o.name, website: o.website_url || o.primary_domain, linkedin_url: o.linkedin_url, industry: o.industry, sub_industry: Array.isArray(o.secondary_industries) && o.secondary_industries[0] ? o.secondary_industries[0] : null, employee_count: o.estimated_num_employees, founded_year: o.founded_year, total_funding_usd: o.total_funding || null, last_round_stage: o.latest_funding_stage || null, last_round_date: o.latest_funding_round_date || null, tech_stack: Array.isArray(o.technology_names) ? o.technology_names.slice(0, 30) : [], annual_revenue: o.annual_revenue || null, hq: { street: o.street_address || null, city: o.city || null, state: o.state || null,   postal_code: o.postal_code || null, country: o.country || null }, source: 'apollo' }; }"
        },
        {
          "alias": "company_core_pdl",
          "tool": "peopledatalabs_company_search",
          "operation": "peopledatalabs_company_search",
          "payload": {
            "query": {
              "term": {
                "website": "{{domain_clean}}"
              }
            },
            "size": 1
          },
          "extract_js": "(output_data) => { const arr = output_data && output_data.result && output_data.result.data; const d = Array.isArray(arr) && arr.length ? arr[0] : null; if (!d || !d.name) return null; return { name: d.display_name || d.name, website: d.website, linkedin_url: d.linkedin_url, industry: d.industry, sub_industry: d.industry_v2 || null, employee_count: d.employee_count, founded_year: d.founded, total_funding_usd: d.total_funding_raised || null, last_round_stage: d.latest_funding_stage || null, last_round_date: d.last_funding_date || null, tech_stack: Array.isArray(d.tags) ? d.tags : [], annual_revenue: d.inferred_revenue || null, hq: { street: d.location && d.location.street_address,   city: d.location && d.location.locality,   state: d.location && d.location.region,   postal_code: d.location && d.location.postal_code,   country: d.location && d.location.country }, source: 'pdl' }; }"
        },
        {
          "alias": "company_core_crustdata",
          "tool": "crustdata_enrich_company",
          "operation": "crustdata_enrich_company",
          "payload": {
            "domain": "{{domain_clean}}"
          },
          "extract_js": "(output_data) => { const r = output_data && output_data.result && output_data.result.result; if (!r || !r.company_name) return null; return { name: r.company_name, website: r.company_domain, linkedin_url: r.linkedin_url, industry: r.industry, sub_industry: null, employee_count: r.employee_count, founded_year: r.founded_year, total_funding_usd: null, last_round_stage: null, last_round_date: null, tech_stack: [], annual_revenue: null, hq: { street: null, city: null, state: null, postal_code: null,   country: null, raw_location: r.location || null }, source: 'crustdata' }; }"
        }
      ]
    },
    {
      "alias": "linkedin_verified",
      "tool": "run_javascript",
      "operation": "run_javascript",
      "payload": {
        "code": "const c = row.company_core || {}; const site = String(c.website||'').toLowerCase(); const domain = String(row.domain_clean||'').toLowerCase(); return Boolean((site && domain && site.includes(domain)) || c.linkedin_url);"
      }
    },
    {
      "alias": "hq_address",
      "tool": "run_javascript",
      "operation": "run_javascript",
      "payload": {
        "code": "const c = row.company_core; return (c && c.hq) ? c.hq : null;"
      }
    },
    {
      "alias": "qualification_pre",
      "tool": "run_javascript",
      "operation": "run_javascript",
      "payload": {
        "code": "const get = (o, p) => p.split('.').reduce((a, k) => (a && a[k] !== undefined && a[k] !== null) ? a[k] : undefined, o); const fails = []; if (!(Number(get(row, \"company_core.employee_count\")||0) >= 50)) fails.push('disqualified:too-small'); { const v = get(row, \"company_core.hq.country\"); if (v === undefined || v === null || v === '') fails.push('disqualified:no-country'); } return { qualification_status: fails.length ? 'disqualified' : 'qualified', qualification_fail_reason: fails.join('; ') };"
      }
    },
    {
      "alias": "company_summary",
      "tool": "deeplineagent",
      "operation": "deeplineagent",
      "payload": {
        "model": "anthropic/claude-haiku-4.5",
        "prompt": "Company: {{company_core.name}} (domain: {{domain_clean}}). Industry: {{company_core.industry}}. Employees: {{company_core.employee_count}}. Founded: {{company_core.founded_year}}. Website: {{company_core.website}}. Write a concise 150-word brief covering: what they sell, target market, company stage. Return JSON only.",
        "jsonSchema": {
          "type": "object",
          "properties": {
            "summary": {
              "type": "string"
            },
            "key_products": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "target_market": {
              "type": "string"
            }
          },
          "required": [
            "summary",
            "key_products",
            "target_market"
          ],
          "additionalProperties": false
        }
      },
      "run_if_js": "return row.qualification_pre && row.qualification_pre.qualification_status === 'qualified';"
    },
    {
      "alias": "classify_company_type",
      "tool": "generic_http_request",
      "operation": "generic_http_request",
      "payload": {
        "method": "POST",
        "url": "https://gateway.latitude.so/api/v3/projects/<LATITUDE_PROJECT_ID>/versions/live/documents/run",
        "headers": {
          "Authorization": "Bearer <LATITUDE_API_KEY>",
          "Content-Type": "application/json"
        },
        "body_json": {
          "path": "category_enrichment/enrichment_classify",
          "parameters": {
            "domain": "{{domain_clean}}",
            "categories_json": "[{\"value\": \"SaaS\", \"label\": \"SaaS\", \"description\": \"A company that sells software, technology, or a platform as its core product, where customers pay for access to the tool itself \\u2014 typically through subscriptions, seat-based pricing, or usage-based licensing. The company sells software tooling to users who pay for access to the tool itself \\u2014 not platforms where the software is incidental to a content, social, or creator-driven network.\", \"positive_signals\": [\"Subscription or seat-based pricing model (monthly or annual plans) for software access\", \"'Book a Demo' or 'Request a Demo' CTA prominently on the website\", \"Self-serve sign-up or free trial for a software product\", \"Product pages describing software features, integrations, or platform capabilities\", \"Job listings for software engineers, product managers, or customer success roles focused on a software product\", \"Customers described as 'users' with references to onboarding, user accounts, or dashboards\"], \"negative_signals\": [\"Core business is delivering human services (consulting, campaign management, design work) even if tech-enabled\", \"Primary revenue from selling physical products via an online storefront\", \"Brick-and-mortar locations as the primary mode of business\", \"Consumer-facing platform or marketplace where the primary value is the content, community, or network created by users \\u2014 not the software tooling itself (e.g., social networks, content platforms, creator economy platforms, language-learning apps)\", \"Platform whose primary revenue model is taking a commission or percentage on transactions between users rather than charging for software seats or subscriptions to use tools\", \"AI research organization or tech company whose products are consumed as consumer utilities or APIs powering other applications, rather than traditional seat-based SaaS\", \"Two-sided marketplace or platform connecting creators/publishers with audiences where the platform itself is the product, not a tool sold to businesses\"]}, {\"value\": \"E-Commerce\", \"label\": \"E-Commerce\", \"description\": \"A company whose primary business is selling physical products online through a digital storefront where consumers can browse and purchase directly on the website. The online channel must be the primary mode of commerce, not a secondary channel to brick-and-mortar retail.\", \"positive_signals\": [\"Digital storefront with product listings, shopping cart, and checkout functionality as the primary sales channel\", \"Product catalog of physical goods with pricing, sizing, or shipping information\", \"Direct-to-consumer (DTC) brand selling physical products primarily through their website\", \"Presence on e-commerce platforms (Shopify, BigCommerce, WooCommerce) or references to online order fulfillment\", \"Marketing focused on product imagery, promotions, and online shopping experience\"], \"negative_signals\": [\"Primarily known for extensive brick-and-mortar retail locations (e.g., Walmart, Target, Home Depot) even if they also sell online\", \"Sells software or digital-only products with no physical goods\", \"Provides services rather than physical products\", \"Marketplace or aggregator that connects buyers and sellers but does not sell its own physical inventory\"]}, {\"value\": \"Digital Agency\", \"label\": \"Digital Agency\", \"description\": \"A company \\u2014 or holding company whose subsidiaries \\u2014 primarily provides web-based or digital services to clients, such as advertising, marketing, public relations, media buying, RevOps, paid advertising, SEO, web development, or cold email, where the core business model is human-delivered services, not software.\", \"positive_signals\": [\"'Book a Call,' 'Book a Consultation,' or 'Book a Meeting' CTAs on the website rather than 'Book a Demo'\", \"Service offerings listed such as SEO, PPC, social media management, web development, content marketing, or RevOps\", \"Case studies or portfolio showcasing client work and campaign results\", \"Team page highlighting strategists, account managers, or creative professionals delivering services\", \"Holding company or parent organization whose portfolio consists primarily of advertising, PR, media, or marketing agencies\", \"Describes itself as operating across communications, advertising, creative, or media services through subsidiary brands or networks\"], \"negative_signals\": [\"Sells a self-serve software product that customers use independently without agency involvement\", \"Revenue comes from software subscriptions or seat-based licensing rather than service retainers or project fees\", \"Marketplace or directory that connects clients with agencies but does not itself deliver services\", \"Sells physical products online as its primary business\"]}, {\"value\": \"Traditional Business\", \"label\": \"Traditional Business\", \"description\": \"A company whose primary mode of business is established, non-digital-native operations \\u2014 including brick-and-mortar retail, financial services, banking, insurance, manufacturing, logistics, healthcare, legal services, or other legacy industries \\u2014 even if it also has an online presence or digital channels as secondary offerings.\", \"positive_signals\": [\"Extensive network of physical retail locations, branches, offices, or facilities as the primary customer touchpoint\", \"Financial institution such as a bank, credit union, insurance company, or investment bank with consumer or commercial banking operations\", \"Large legacy enterprise operating in established industries (finance, energy, healthcare, manufacturing, transportation)\", \"Regulated industry participant (banking, insurance, securities) with physical branch networks or institutional operations\", \"Company founded before the internet era whose core business model predates digital commerce\", \"Known primarily for in-person or physical-world operations (retail stores, factories, hospitals, law offices) rather than digital products\", \"Globally recognized brand with heritage in physical retail or wholesale, even if it has a strong DTC e-commerce channel\"], \"negative_signals\": [\"Primary business is selling software or a digital platform to customers\", \"Digital-native company that was born online with no legacy physical operations\", \"Revenue primarily comes from online sales of physical goods through a digital storefront (e-commerce-first)\", \"Core offering is human-delivered digital marketing or web services (digital agency model)\", \"Digital-native platform or marketplace that exists primarily online with no legacy physical operations\"]}, {\"value\": \"Other\", \"label\": \"Other\", \"description\": \"A company that does not clearly fit into SaaS, E-Commerce, Digital Agency, or Traditional Business \\u2014 typically internet-native platforms, marketplaces, social networks, content platforms, creator economy businesses, AI research organizations, non-profit or humanitarian organizations, or other digital-native companies whose business model is distinct from traditional software sales, physical product e-commerce, service delivery, or legacy brick-and-mortar operations.\", \"positive_signals\": [\"Two-sided marketplace or directory connecting buyers with sellers or service providers without delivering services itself (e.g., Clutch, G2)\", \"Social media platform, content network, or community-driven platform where users generate the core value (e.g., Reddit, Substack, Patreon)\", \"Creator economy platform that monetizes through commissions on creator revenue rather than software seat pricing\", \"AI research organization or consumer technology company whose products are consumed as utilities or APIs rather than traditional SaaS tools (e.g., OpenAI)\", \"Consumer app or platform (e.g., Duolingo) where the primary experience is content or engagement, not business software tooling\", \"Revenue model based on advertising, commissions, or freemium consumer access rather than B2B software subscriptions or service retainers\", \"Non-profit, NGO, or humanitarian organization with physical service delivery (e.g., aid distribution, community programs) that does not operate as a traditional commercial business\"], \"negative_signals\": [\"Sells software via subscription with seat-based or usage-based pricing as a tool for business users (SaaS)\", \"Sells physical products directly to consumers through an online storefront (E-Commerce)\", \"Delivers human services like marketing, SEO, or web development to clients (Digital Agency)\", \"Operates primarily through physical locations, branches, or legacy industry infrastructure (Traditional Business)\"]}, {\"value\": \"Internet Business\", \"label\": \"Internet Business\", \"description\": \"A digital-native company whose primary business exists online as a platform, marketplace, social network, content ecosystem, or consumer technology product \\u2014 distinct from traditional SaaS (which sells software tooling via seats/subscriptions) and distinct from e-commerce (which sells physical products). The company's core value proposition is the network, content, community, or digital experience it enables, not a software tool sold to business users.\", \"positive_signals\": [\"Two-sided marketplace or aggregator platform connecting buyers with sellers, creators with audiences, or service seekers with providers (e.g., Clutch, G2, Airbnb)\", \"Social media or community platform where user-generated content drives the core experience (e.g., Reddit)\", \"Creator economy or publishing platform that takes a commission on transactions between creators and subscribers (e.g., Substack, Patreon)\", \"Consumer-facing app or platform centered on engagement, learning, or entertainment rather than business software tooling (e.g., Duolingo)\", \"AI research organization or consumer tech company offering products as consumer utilities, APIs, or freemium tools rather than seat-based enterprise SaaS (e.g., OpenAI)\", \"Revenue model based on advertising, transaction commissions, or freemium consumer access\"], \"negative_signals\": [\"Sells software as a B2B tool with seat-based or subscription pricing where customers pay for access to software functionality (SaaS)\", \"Primarily sells physical products through an online storefront (E-Commerce)\", \"Delivers human services like marketing, consulting, or web development to clients (Digital Agency)\", \"Operates primarily through physical locations or legacy industry infrastructure (Traditional Business)\", \"Company's core value is the software tool itself rather than the network, content, or marketplace it facilitates\"]}]"
          },
          "stream": false
        },
        "timeout_ms": 60000
      },
      "extract_js": "(output_data) => { const r = (output_data && output_data.result) || output_data || {}; const body = r.body || r.data || r; const resp = body && body.response; if (!resp) return null; let obj = resp.object; if (!obj && resp.text) {   if (typeof resp.text === 'object') { obj = resp.text; }   else if (typeof resp.text === 'string' && resp.text.trim()) {     try { obj = JSON.parse(resp.text.replace(/^```json\\n?/, '').replace(/\\n?```$/, '')); } catch (e) {}   } } if (!obj) return null; const out = { object: {} }; out.object[\"company_type\"] = obj.category; out.object[\"company_type_label\"] = obj.category_label; out.object[\"company_type_reasoning\"] = obj.reasoning; out.object[\"company_type_summary\"] = obj.summary;  return out; }",
      "run_if_js": "return row.qualification_pre && row.qualification_pre.qualification_status === 'qualified';"
    },
    {
      "alias": "qualification_post",
      "tool": "run_javascript",
      "operation": "run_javascript",
      "payload": {
        "code": "const get = (o, p) => p.split('.').reduce((a, k) => (a && a[k] !== undefined && a[k] !== null) ? a[k] : undefined, o); const up = row.qualification_pre; if (up && up.qualification_status === 'disqualified') return { qualification_status: 'disqualified', qualification_fail_reason: up.qualification_fail_reason }; const fails = []; if (![\"SaaS\"].includes(get(row, \"classify_company_type.response.text.category\"))) fails.push('disqualified:non-saas'); return { qualification_status: fails.length ? 'disqualified' : 'qualified', qualification_fail_reason: fails.join('; ') };"
      }
    },
    {
      "alias": "revops_headcount",
      "tool": "company_to_contact_by_role_waterfall",
      "operation": "company_to_contact_by_role_waterfall",
      "payload": {
        "domain": "{{domain_clean}}",
        "roles": [
          "revenue operations"
        ]
      },
      "run_if_js": "return row.qualification_post && row.qualification_post.qualification_status === 'qualified';"
    }
  ]
}